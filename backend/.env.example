APP_NAME="X1Techs CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=debug

# CRM Database (local Docker Postgres on 5433)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=crm_dev
DB_USERNAME=crm_user
