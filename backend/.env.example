# n8n Database (read-only — requires SSH tunnel: bash scripts/tunnel-start.sh)
N8N_DB_HOST=host.docker.internal
N8N_DB_PORT=5434
N8N_DB_DATABASE=n8n_db
N8N_DB_USERNAME=n8n_user
N8N_DB_PASSWORD=CHANGE_ME

